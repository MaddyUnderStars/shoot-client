{
	"$schema": "./node_modules/oxlint/configuration_schema.json",
	"plugins": ["typescript", "unicorn", "oxc"],
	"ignorePatterns": ["src/routeTree.gen.ts", "src/lib/http/generated/**"],
	"categories": {
		"correctness": "error",
		"suspicious": "warn"
	},
	"rules": {
		"eslint/eqeqeq": "warn",
		"eslint/no-shadow": "off"
	},
	"env": {
		"builtin": true
	},
	"options": {
		"typeAware": true
	}
}
